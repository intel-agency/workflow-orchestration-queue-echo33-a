# ============================================================================
# Workflow Orchestration Queue - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Then source it before running scripts:
#   set -a; source .env; set +a
#
# Or use the setup helper:
#   bash scripts/setup-local-env.sh
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Application will not start without these
# ---------------------------------------------------------------------------

# GitHub Personal Access Token for queue operations
# Required scopes: repo (for Issues API), workflow
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Repository in 'owner/repo' format
# Example: octocat/Hello-World
GITHUB_REPOSITORY=intel-agency/workflow-orchestration-queue-echo33-a

# ---------------------------------------------------------------------------
# OPTIONAL — Application Settings (defaults shown)
# ---------------------------------------------------------------------------

# Application environment (development, staging, production, testing)
# Default: development
APP_ENV=development

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# OPTIONAL — Notifier Service Configuration
# ---------------------------------------------------------------------------

# Secret for verifying GitHub webhook signatures
# Generate with: openssl rand -hex 32
# If not set, webhook signature verification is disabled (not recommended for production)
NOTIFIER_WEBHOOK_SECRET=

# Service name for logging and identification
# Default: workflow-orchestration-queue
NOTIFIER_SERVICE_NAME=workflow-orchestration-queue

# ---------------------------------------------------------------------------
# OPTIONAL — Sentinel Orchestrator Configuration
# ---------------------------------------------------------------------------

# GitHub username for the sentinel bot (used for task claiming)
# If not set, distributed locking is disabled (single sentinel mode only)
SENTINEL_BOT_LOGIN=

# Seconds between polling cycles for queued tasks
# Default: 60.0
# Range: 1.0 - 3600.0
SENTINEL_POLL_INTERVAL=60.0

# Seconds between heartbeat posts during task execution
# Default: 300.0 (5 minutes)
# Range: 10.0 - 3600.0
SENTINEL_HEARTBEAT_INTERVAL=300.0

# Maximum seconds for subprocess execution (safety net)
# Default: 5700.0 (95 minutes)
# Range: 60.0 - 86400.0
SENTINEL_SUBPROCESS_TIMEOUT=5700.0

# Base backoff interval for error recovery (seconds)
# Used for exponential backoff when polling fails
# Default: 5.0
# Range: 1.0 - 60.0
SENTINEL_BACKOFF_BASE_SECONDS=5.0

# Maximum backoff interval cap (seconds)
# Default: 300.0 (5 minutes)
# Range: 10.0 - 3600.0
SENTINEL_BACKOFF_MAX_SECONDS=300.0

# Path to the shell bridge script for devcontainer operations
# Default: ./scripts/devcontainer-opencode.sh
SENTINEL_SHELL_BRIDGE_PATH=./scripts/devcontainer-opencode.sh

# ---------------------------------------------------------------------------
# LEGACY — Orchestration Agent Configuration (for opencode)
# ---------------------------------------------------------------------------

# GitHub Personal Access Token (org-level PAT) for orchestration agent
# Required scopes: repo, workflow, project, read:org
# Used by: gh CLI, opencode MCP GitHub server, orchestrator agent
GH_ORCHESTRATION_AGENT_TOKEN=

# ZhipuAI API key — access to GLM models (primary model provider)
ZHIPU_API_KEY=

# Kimi / Moonshot API key — backup model provider
KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY=

# ---------------------------------------------------------------------------
# LEGACY — Alternative Model Providers (optional)
# ---------------------------------------------------------------------------

# OpenAI API key (GPT models)
# OPENAI_API_KEY=

# Google Gemini API key (mapped to GOOGLE_GENERATIVE_AI_API_KEY in container)
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# LEGACY — OpenCode Server Configuration (optional)
# ---------------------------------------------------------------------------

# Bind address for opencode serve (0.0.0.0 = all interfaces)
# OPENCODE_SERVER_HOSTNAME=0.0.0.0

# Listen port for opencode serve
# OPENCODE_SERVER_PORT=4096

# Basic auth credentials — when set, clients must include these in attach URLs
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=
